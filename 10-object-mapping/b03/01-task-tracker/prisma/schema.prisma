generator client {
  provider = "prisma-client-js"
  output   = "client"
}

datasource db {
  provider = "sqlite"
}

model User {
  id    String  @id @default(cuid(2))
  email String  @unique
  name  String?
  karma Int     @default(0)
  posts Post[]
}

model Post {
  id         String  @id @default(cuid(2))
  title      String
  content    String?
  published  Boolean @default(false)
  postAuthor User    @relation(fields: [author], references: [id])
  author     String
}
