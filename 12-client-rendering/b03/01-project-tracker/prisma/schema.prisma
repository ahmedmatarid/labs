generator client {
  provider = "prisma-client-js"
  output   = "client"
}

datasource db {
  provider = "sqlite"
}

model Project {
  id        String   @id @default(cuid(2))
  title     String   @unique
  completed Boolean  @default(false)
  date      DateTime @default(now())
  tasks     Task[]
}

model Task {
  id          String   @id @default(cuid(2))
  title       String   @unique
  completed   Boolean  @default(false)
  date        DateTime @default(now())
  projectTask Project  @relation(fields: [project], references: [id])
  project     String
}
